{
  "info": {
    "name": "Ligo Wallet Service",
    "_postman_id": "ligo-wallet-service-v2",
    "description": "Ligo Backend Senior Challenge — Wallet Transaction Microservice\n\n**Flujo recomendado:**\n1. Ejecutar `POST /auth/login` → el token se guarda automáticamente\n2. Usar los demás requests con `{{token}}` ya cargado\n3. Los requests de Transactions generan `{{idempotencyKey}}` y guardan `{{lastTxnId}}` y `{{lastUserId}}` automáticamente",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",        "value": "http://localhost:3000", "type": "string" },
    { "key": "token",          "value": "", "type": "string" },
    { "key": "idempotencyKey", "value": "", "type": "string" },
    { "key": "lastTxnId",      "value": "", "type": "string" },
    { "key": "lastUserId",     "value": "", "type": "string" }
  ],
  "item": [
