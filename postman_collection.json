              "raw": "{\n  \"walletId\": \"wal_001\",\n  \"type\": \"DEBIT\",\n  \"amount\": \"25.50\",\n  \"currency\": \"PEN\",\n  \"description\": \"Pago QR comercio\",\n  \"externalReference\": \"qr_789456\"\n}"
