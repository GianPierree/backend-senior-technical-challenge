          "name": "POST /auth/login — válido",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('token', json.token);",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tiene token', () => pm.expect(json.token).to.be.a('string'));",
                  "pm.test('expiresIn es 3600', () => pm.expect(json.expiresIn).to.eql(3600));"
