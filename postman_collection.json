    {
      "name": "Transactions",
      "item": [
        {
          "name": "POST /transactions — DEBIT",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('idempotencyKey', pm.variables.replaceIn('{{$guid}}'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Status COMPLETED', () => pm.expect(json.status).to.eql('COMPLETED'));",
                  "pm.test('Type DEBIT', () => pm.expect(json.type).to.eql('DEBIT'));",
                  "pm.test('Amount es string decimal', () => pm.expect(json.amount).to.match(/^\\d+\\.\\d{2}$/));",
                  "if (json.transactionId) pm.collectionVariables.set('lastTxnId', json.transactionId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization",  "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" },
              { "key": "Idempotency-Key","value": "{{idempotencyKey}}" }
            ],
            "url": "{{baseUrl}}/transactions",
            "body": {
